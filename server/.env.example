# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/schedulecat

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration (SendGrid - Free Option)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDER_EMAIL=your-email@gmail.com

# Server Configuration
PORT=5000

# Instructions for SendGrid Setup:
# 1. Create free SendGrid account at https://sendgrid.com
# 2. Go to Settings > API Keys > Create API Key
# 3. Choose "Full Access" and copy the API key
# 4. Verify your sender email address in SendGrid
# 5. Use your verified email as SENDER_EMAIL
